{
  "name": "spec-points-api",
  "version": "1.0.0",
  "description": "SpecPoints Backend API - Express + TypeScript + Firebase + PostgreSQL",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrate.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest"
  },
  "keywords": [
    "api",
    "express",
    "backend",
    "specpoints",
    "loyalty",
    "points"
  ],
  "author": "SpecPoints Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "pg-promise": "^11.5.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^7.0.0",
    "dotenv": "^16.3.0",
    "zod": "^3.22.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/express": "^4.17.20",
    "@types/node": "^20.9.0",
    "@types/cors": "^2.8.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "tsx": "^4.0.0",
    "eslint": "^8.53.0",
    "vitest": "^0.34.0",
    "supertest": "^6.3.0",
    "@types/supertest": "^2.0.12"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
